<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MauiApp1.Models"
             xmlns:vm="clr-namespace:MauiApp1.ViewModels"
             x:Class="MauiApp1.Views.AdminSystemsPage"
             x:Name="ThisPage"
             x:DataType="vm:AdminSystemsViewModel"
             Title="Business systems">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Add button at the top, always visible -->
    <Button Grid.Row="0"
            Text="+ Add system"
            Command="{Binding AddCommand}"
            Margin="16,12" />

    <RefreshView Grid.Row="1"
                 IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding LoadCommand}">

      <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">

        <CollectionView.EmptyView>
          <VerticalStackLayout Padding="40" Spacing="12"
                               VerticalOptions="Center" HorizontalOptions="Center">
            <Label Text="No systems yet"
                   FontSize="18" FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Add business systems so requesters can pick from a dropdown instead of typing free text."
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
            <Button Text="Seed example systems"
                    Command="{Binding SeedExamplesCommand}"
                    Margin="0,8,0,0" />
          </VerticalStackLayout>
        </CollectionView.EmptyView>

        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:BusinessSystem">
            <Border Margin="16,8" Padding="14" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
              <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
              </Border.StrokeShape>

              <Border.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding BindingContext.EditCommand, Source={x:Reference ThisPage}}"
                    CommandParameter="{Binding .}" />
              </Border.GestureRecognizers>

              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="{Binding Name}"
                       FontSize="16" FontAttributes="Bold"
                       LineBreakMode="TailTruncation" />

                <!-- Active/inactive badge -->
                <Border Grid.Row="0" Grid.Column="1"
                        Padding="8,2"
                        VerticalOptions="Center">
                  <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                  </Border.StrokeShape>
                  <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                      <Setter Property="BackgroundColor" Value="#1B873F" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                      <Setter Property="BackgroundColor" Value="#667085" />
                    </DataTrigger>
                  </Border.Triggers>
                  <Label TextColor="White" FontSize="11" FontAttributes="Bold">
                    <Label.Triggers>
                      <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                        <Setter Property="Text" Value="Active" />
                      </DataTrigger>
                      <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                        <Setter Property="Text" Value="Inactive" />
                      </DataTrigger>
                    </Label.Triggers>
                  </Label>
                </Border>

                <Label Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{Binding Description}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                       MaxLines="2"
                       LineBreakMode="TailTruncation" />

                <Label Grid.Row="2" Grid.ColumnSpan="2"
                       Text="{Binding AvailableRoles.Count, StringFormat='{}{0} role(s) configured'}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
              </Grid>
            </Border>
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>
    </RefreshView>

    <Label Grid.Row="2"
           Text="{Binding ErrorMessage}"
           TextColor="White"
           BackgroundColor="DarkRed"
           Padding="16,12"
           IsVisible="{Binding HasError}" />
  </Grid>
</ContentPage>
