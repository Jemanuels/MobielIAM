<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.DashboardPage"
             Title="Dashboard">

  <ContentPage.Resources>
    <ResourceDictionary>
      <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="StrokeShape">
          <Setter.Value>
            <RoundRectangle CornerRadius="12" />
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="CardNumber" TargetType="Label">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
      </Style>
      <Style x:Key="CardCaption" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
      </Style>
      <Style x:Key="SectionHeader" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Margin" Value="0,8,0,0" />
      </Style>
    </ResourceDictionary>
  </ContentPage.Resources>

  <ScrollView>
    <VerticalStackLayout Padding="20" Spacing="16">

      <Label Text="{Binding GreetingText}" FontSize="24" FontAttributes="Bold" />
      <Label Text="{Binding RoleText}" FontSize="14"
             TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

      <!-- ============== REQUESTER ============== -->
      <VerticalStackLayout IsVisible="{Binding IsRequester}" Spacing="12">
        <Label Text="My access requests" Style="{StaticResource SectionHeader}" />
        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="12" ColumnSpacing="12">
          <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding SubmittedCount}" Style="{StaticResource CardNumber}" />
              <Label Text="Submitted" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
          <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding PendingCount}" Style="{StaticResource CardNumber}" />
              <Label Text="Pending" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
          <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding ApprovedCount}" Style="{StaticResource CardNumber}" TextColor="Green" />
              <Label Text="Approved" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
          <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding RejectedCount}" Style="{StaticResource CardNumber}" TextColor="DarkRed" />
              <Label Text="Rejected" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
        </Grid>
        <Button Text="New access request" Command="{Binding GoToNewRequestCommand}" />
        <Button Text="View my requests"
                Command="{Binding GoToMyRequestsCommand}"
                BackgroundColor="Transparent"
                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
      </VerticalStackLayout>

      <!-- ============== APPROVER ============== -->
      <VerticalStackLayout IsVisible="{Binding IsApprover}" Spacing="12">
        <Label Text="Approval queue" Style="{StaticResource SectionHeader}" />
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
          <Border Grid.Column="0" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding PendingApprovalsCount}" Style="{StaticResource CardNumber}" />
              <Label Text="Pending" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding RecentlyApprovedCount}" Style="{StaticResource CardNumber}" TextColor="Green" />
              <Label Text="Approved" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
          <Border Grid.Column="2" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding RecentlyRejectedCount}" Style="{StaticResource CardNumber}" TextColor="DarkRed" />
              <Label Text="Rejected" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
        </Grid>
        <Button Text="Open approval queue"
                Command="{Binding GoToApprovalQueueCommand}" />
      </VerticalStackLayout>

      <!-- ============== ADMIN ============== -->
      <VerticalStackLayout IsVisible="{Binding IsAdmin}" Spacing="12">
        <Label Text="System overview" Style="{StaticResource SectionHeader}" />
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
          <Border Grid.Column="0" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding TotalUsersCount}" Style="{StaticResource CardNumber}" />
              <Label Text="Users" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding TotalSystemsCount}" Style="{StaticResource CardNumber}" />
              <Label Text="Systems" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
          <Border Grid.Column="2" Style="{StaticResource StatCard}">
            <VerticalStackLayout>
              <Label Text="{Binding TotalRequestsCount}" Style="{StaticResource CardNumber}" />
              <Label Text="Requests" Style="{StaticResource CardCaption}" />
            </VerticalStackLayout>
          </Border>
        </Grid>
        <Button Text="Open approval queue"
                Command="{Binding GoToApprovalQueueCommand}" />
        <Button Text="Manage business systems"
                Command="{Binding GoToAdminSystemsCommand}" />
        <Button Text="Manage users"
                Command="{Binding ComingSoonCommand}"
                CommandParameter="User management" />
        <Button Text="View audit log"
                Command="{Binding ComingSoonCommand}"
                CommandParameter="Audit log" />
      </VerticalStackLayout>

      <Button Text="Logout"
              Command="{Binding LogoutCommand}"
              BackgroundColor="DarkRed"
              TextColor="White"
              Margin="0,24,0,0" />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
